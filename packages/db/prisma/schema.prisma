generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  OWNER
  ADMIN
  INSTRUCTOR
  MODERATOR
  STUDENT
  REVIEWER
}

enum CertificateStatus {
  VALID
  REVOKED
  EXPIRED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model EmailVerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  email         String    @unique
  passwordHash  String
  avatarUrl     String?
  jobTitle      String?
  company       String?
  phone         String?
  status        String    @default("active")
  termsAccepted Boolean   @default(false)
  privacyPolicyAccepted Boolean @default(false)
  locale        String    @default("pt-BR")
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships Membership[]
  enrollments Enrollment[]
  quizAttempts QuizAttempt[]
  submissions  Submission[]
  certificates Certificate[]
  consents     Consent[]
  posts        CommunityPost[]
  comments     CommunityComment[]
  reactions    CommunityReaction[]
  sessions     Session[]
  auditLogs    AuditLog[] @relation("ActorLogs")

  @@index([tenantId])
}

model Organization {
  id          String    @id @default(cuid())
  tenantId    String    @unique
  name        String
  slug        String    @unique
  billingMode String    @default("manual")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships Membership[]
}

model Membership {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  organizationId String
  roleId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, organizationId])
  @@index([tenantId])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  code        RoleCode
  name        String
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())
}

model Course {
  id          String    @id
  tenantId    String
  title       String
  slug        String
  language    String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  versions    CourseVersion[]
  finalChallenges FinalChallenge[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model CourseVersion {
  id        String   @id @default(cuid())
  tenantId  String
  courseId  String
  version   String
  status    String   @default("draft")
  metadata  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course    Course   @relation(fields: [courseId], references: [id])
  modules   Module[]
  enrollments Enrollment[]

  @@unique([courseId, version])
  @@index([tenantId])
}

model Module {
  id              String   @id
  tenantId        String
  courseVersionId String
  code            String
  title           String
  sortOrder       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courseVersion CourseVersion @relation(fields: [courseVersionId], references: [id])
  cycles        Cycle[]
  projects      Project[]

  @@unique([courseVersionId, code])
  @@index([tenantId])
}

model Cycle {
  id        String   @id
  tenantId  String
  moduleId  String
  code      String
  title     String
  content   Json
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module    Module    @relation(fields: [moduleId], references: [id])
  lessonBlocks LessonBlock[]
  activities   Activity[]
  questions    Question[]
  quizAttempts QuizAttempt[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model LessonBlock {
  id        String   @id
  tenantId  String
  cycleId   String
  title     String
  kind      String
  body      String
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cycle     Cycle    @relation(fields: [cycleId], references: [id])

  @@index([tenantId, cycleId])
}

model Activity {
  id        String   @id
  tenantId  String
  cycleId   String
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cycle     Cycle    @relation(fields: [cycleId], references: [id])
  submissions Submission[]

  @@index([tenantId, cycleId])
}

model Rubric {
  id        String   @id @default(cuid())
  tenantId  String
  ownerType String
  ownerId   String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  criteria  RubricCriterion[]

  @@index([tenantId, ownerType, ownerId])
}

model RubricCriterion {
  id        String   @id @default(cuid())
  tenantId  String
  rubricId  String
  title     String
  levels    Json
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rubric    Rubric   @relation(fields: [rubricId], references: [id])

  @@index([tenantId, rubricId])
}

model Question {
  id              String   @id
  tenantId        String
  cycleId         String
  difficulty      String
  prompt          String
  correctOptionId String
  explanation     String
  theme           String
  source          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cycle           Cycle    @relation(fields: [cycleId], references: [id])
  options         QuestionOption[]
  attemptAnswers  QuizAttemptAnswer[]

  @@index([tenantId, cycleId])
}

model QuestionOption {
  id         String   @id
  tenantId   String
  questionId String
  label      String
  text       String
  feedback   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question   Question @relation(fields: [questionId], references: [id])
  attemptAnswers QuizAttemptAnswer[]

  @@index([tenantId, questionId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  cycleId     String
  seed        String
  score       Int
  passed      Boolean
  submittedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  cycle       Cycle    @relation(fields: [cycleId], references: [id])
  answers     QuizAttemptAnswer[]

  @@index([tenantId, userId, cycleId])
}

model QuizAttemptAnswer {
  id              String   @id @default(cuid())
  tenantId        String
  attemptId       String
  questionId      String
  selectedOptionId String
  correct         Boolean
  createdAt       DateTime @default(now())

  attempt         QuizAttempt @relation(fields: [attemptId], references: [id])
  question        Question    @relation(fields: [questionId], references: [id])
  selectedOption  QuestionOption @relation(fields: [selectedOptionId], references: [id])

  @@index([tenantId, attemptId])
}

model Enrollment {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String
  courseVersionId String
  status          String    @default("active")
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  courseVersion CourseVersion @relation(fields: [courseVersionId], references: [id])

  @@unique([tenantId, userId, courseVersionId])
  @@index([tenantId])
}

model ProgressEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  cycleId   String?
  eventType String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
}

model Submission {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  activityId  String?
  projectId   String?
  challengeId String?
  status      String    @default("submitted")
  payload     Json
  score       Int?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  activity    Activity? @relation(fields: [activityId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  challenge   FinalChallenge? @relation(fields: [challengeId], references: [id])

  @@index([tenantId, userId])
}

model Project {
  id        String   @id
  tenantId  String
  moduleId  String
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module      Module      @relation(fields: [moduleId], references: [id])
  submissions Submission[]

  @@index([tenantId, moduleId])
}

model FinalChallenge {
  id        String   @id
  tenantId  String
  courseId  String
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course      Course      @relation(fields: [courseId], references: [id])
  submissions Submission[]

  @@index([tenantId, courseId])
}

model Certificate {
  id              String            @id @default(cuid())
  tenantId        String
  userId          String
  courseVersionId String
  code            String            @unique
  status          CertificateStatus @default(VALID)
  issuedAt        DateTime          @default(now())
  revokedAt       DateTime?
  expiresAt       DateTime?
  payload         Json
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user          User @relation(fields: [userId], references: [id])
  verifications CertificateVerification[]

  @@index([tenantId, userId])
}

model CertificateVerification {
  id            String   @id @default(cuid())
  certificateId String
  code          String
  ipHash        String?
  userAgentHash String?
  result        String
  createdAt     DateTime @default(now())

  certificate   Certificate @relation(fields: [certificateId], references: [id])

  @@index([code])
}

model SourceFile {
  id             String   @id @default(cuid())
  name           String
  sha256         String   @unique
  path           String
  priority       String
  condition      String
  metadata       Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  chunks         SourceChunk[]
}

model SourceChunk {
  id           String   @id @default(cuid())
  sourceFileId String
  cycleId      String?
  text         String
  metadata     Json
  createdAt    DateTime @default(now())

  sourceFile   SourceFile @relation(fields: [sourceFileId], references: [id])

  @@index([sourceFileId])
}

model ContentAudit {
  id        String   @id @default(cuid())
  tenantId  String
  entity    String
  entityId  String
  action    String
  note      String
  createdAt DateTime @default(now())

  @@index([tenantId, entity, entityId])
}

model ConflictLog {
  id        String   @id @default(cuid())
  sourceA   String
  sourceB   String
  decision  String
  rationale String
  createdAt DateTime @default(now())
}

model Consent {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  version     String
  purpose     String
  accepted    Boolean
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorId     String?
  action      String
  entity      String
  entityId    String?
  before      Json?
  after       Json?
  metadata    Json
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor       User?    @relation("ActorLogs", fields: [actorId], references: [id])

  @@index([tenantId, actorId])
  @@index([tenantId, entity, entityId])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  channel   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, channel])
}

model AIInteractionLog {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  mode           String
  promptHash     String
  redactedPrompt String
  response       String?
  consentToStore Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([tenantId, userId])
}

model PromptTemplate {
  id        String   @id
  tenantId  String
  cycleId   String?
  title     String
  template  String
  metadata  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, cycleId])
}

model AutomationTemplate {
  id        String   @id
  tenantId  String
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model AutomationSimulation {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  flow       Json
  logs       Json
  valid      Boolean
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
}

model ImportJob {
  id        String    @id @default(cuid())
  tenantId  String
  status    JobStatus @default(QUEUED)
  source    String
  result    Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, status])
}

model CommunityCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     CommunityPost[]

  @@unique([tenantId, slug])
}

model CommunityPost {
  id         String    @id @default(cuid())
  tenantId   String
  authorId   String
  categoryId String
  courseId   String?
  moduleId   String?
  title      String
  content    String
  isOfficial Boolean   @default(false)
  isResolved Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  author     User              @relation(fields: [authorId], references: [id])
  category   CommunityCategory @relation(fields: [categoryId], references: [id])
  comments   CommunityComment[]
  reactions  CommunityReaction[]

  @@index([tenantId, categoryId])
  @@index([tenantId, authorId])
}

model CommunityComment {
  id         String    @id @default(cuid())
  tenantId   String
  postId     String
  authorId   String
  content    String
  isOfficial Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  post       CommunityPost      @relation(fields: [postId], references: [id])
  author     User               @relation(fields: [authorId], references: [id])
  reactions  CommunityReaction[]

  @@index([tenantId, postId])
}

model CommunityReaction {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  postId    String?
  commentId String?
  emoji     String
  createdAt DateTime @default(now())

  user      User              @relation(fields: [userId], references: [id])
  post      CommunityPost?    @relation(fields: [postId], references: [id])
  comment   CommunityComment? @relation(fields: [commentId], references: [id])

  @@index([tenantId, userId])
}

model CommunityReport {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  postId    String?
  commentId String?
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model ModerationAction {
  id        String   @id @default(cuid())
  tenantId  String
  moderatorId String
  postId    String?
  commentId String?
  action    String
  reason    String?
  createdAt DateTime @default(now())
}

model SecurityEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  type      String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([tenantId, type])
}

model SystemSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
}

model DeletionRequest {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  reason     String?
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  executedAt DateTime?
}

model ExportJob {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  status    JobStatus @default(QUEUED)
  kind      String
  resultUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, userId, status])
}

model BillingRecord {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  provider    String
  externalId  String?
  status      String
  amountCents Int
  currency    String   @default("BRL")
  metadata    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}
