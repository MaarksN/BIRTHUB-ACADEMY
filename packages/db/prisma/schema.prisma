generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  OWNER
  ADMIN
  INSTRUCTOR
  EVALUATOR
  STUDENT
}

enum CertificateStatus {
  VALID
  REVOKED
  EXPIRED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  email         String    @unique
  passwordHash  String
  locale        String    @default("pt-BR")
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships  Membership[]
  sessions      Session[]
  enrollments   Enrollment[]
  progressEvents ProgressEvent[]
  cycleCompletions CycleCompletion[]
  quizAttempts  QuizAttempt[]
  submissions   Submission[]
  certificates  Certificate[]
  learningPlans LearningPlan[]
  supportTickets SupportTicket[]
  qualityScoresCreated CourseQualityScore[] @relation("QualityScoreCreator")

  @@index([tenantId])
}

model Organization {
  id          String    @id @default(cuid())
  tenantId    String    @unique
  name        String
  slug        String    @unique
  billingMode String    @default("manual")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships Membership[]
  sessions    Session[]
  roles       Role[]
  courses     Course[]
}

model Session {
  id             String        @id @default(cuid())
  tokenHash      String        @unique
  userId         String
  activeTenantId String
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [activeTenantId], references: [tenantId], onDelete: Cascade)

  @@index([userId, activeTenantId, expiresAt])
  @@index([tokenHash, revokedAt])
}

model Membership {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  organizationId String
  roleId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@index([tenantId, userId])
  @@index([roleId])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  code        RoleCode
  name        String
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  organization Organization @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  memberships Membership[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  createdAt   DateTime @default(now())
}

model Course {
  id          String    @id
  tenantId    String
  title       String
  slug        String
  language    String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  organization Organization @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  versions    CourseVersion[]
  challenges  FinalChallenge[]
  qualityScores CourseQualityScore[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model CourseVersion {
  id        String   @id @default(cuid())
  tenantId  String
  courseId  String
  version   String
  status    String   @default("draft")
  metadata  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  modules   Module[]
  enrollments Enrollment[]
  certificates Certificate[]

  @@unique([tenantId, courseId, version])
  @@index([tenantId, courseId])
}

model Module {
  id              String   @id
  tenantId        String
  courseVersionId String
  code            String
  title           String
  sortOrder       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  courseVersion   CourseVersion @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  cycles          Cycle[]
  projects        Project[]

  @@unique([courseVersionId, code])
  @@index([tenantId])
}

model Cycle {
  id        String   @id
  tenantId  String
  moduleId  String
  code      String
  title     String
  content   Json
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonBlocks LessonBlock[]
  activities Activity[]
  questions Question[]
  quizAttempts QuizAttempt[]
  progressEvents ProgressEvent[]
  completions CycleCompletion[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model LessonBlock {
  id        String   @id
  tenantId  String
  cycleId   String
  title     String
  kind      String
  body      String
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cycle     Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([tenantId, cycleId])
}

model Activity {
  id        String   @id
  tenantId  String
  cycleId   String
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cycle     Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([tenantId, cycleId])
}

model Rubric {
  id        String   @id @default(cuid())
  tenantId  String
  ownerType String
  ownerId   String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  criteria  RubricCriterion[]

  @@index([tenantId, ownerType, ownerId])
}

model RubricCriterion {
  id        String   @id @default(cuid())
  tenantId  String
  rubricId  String
  title     String
  levels    Json
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rubric    Rubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  scores    ReviewScore[]

  @@index([tenantId, rubricId])
}

model Question {
  id              String   @id
  tenantId        String
  cycleId         String
  difficulty      String
  prompt          String
  correctOptionId String?
  explanation     String
  theme           String
  source          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cycle           Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  options         QuestionOption[] @relation("QuestionOptions")
  correctOption   QuestionOption? @relation("CorrectOption", fields: [correctOptionId], references: [id], onDelete: Restrict)
  answers         QuizAttemptAnswer[]

  @@index([tenantId, cycleId])
}

model QuestionOption {
  id         String   @id
  tenantId   String
  questionId String
  label      String
  text       String
  feedback   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation("QuestionOptions", fields: [questionId], references: [id], onDelete: Cascade)
  correctFor Question[] @relation("CorrectOption")
  selectedAnswers QuizAttemptAnswer[]

  @@index([tenantId, questionId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  cycleId     String
  seed        String
  score       Int
  passed      Boolean
  status      AttemptStatus @default(IN_PROGRESS)
  submittedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle       Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  answers     QuizAttemptAnswer[]

  @@index([tenantId, userId, cycleId])
}

model QuizAttemptAnswer {
  id              String   @id @default(cuid())
  tenantId        String
  attemptId       String
  questionId      String
  selectedOptionId String
  correct         Boolean
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  attempt         QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption  QuestionOption @relation(fields: [selectedOptionId], references: [id], onDelete: Restrict)

  @@unique([attemptId, questionId])
  @@index([tenantId, attemptId])
}

model Enrollment {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String
  courseVersionId String
  status          String    @default("active")
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseVersion   CourseVersion @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, courseVersionId])
  @@index([tenantId])
}

model ProgressEvent {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  cycleId   String?
  eventType String
  metadata  Json
  createdAt DateTime @default(now())
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle     Cycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId])
}

model CycleCompletion {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  cycleId     String
  completedAt DateTime @default(now())
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle       Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, cycleId])
  @@index([tenantId, userId, completedAt])
}

model Submission {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  activityId  String?
  projectId   String?
  challengeId String?
  status      SubmissionStatus @default(SUBMITTED)
  payload     Json
  score       Int?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity    Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  challenge   FinalChallenge? @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  files       SubmissionFile[]
  reviews     Review[]

  @@index([tenantId, userId])
  @@index([tenantId, status, createdAt])
}

model SubmissionFile {
  id           String   @id @default(cuid())
  tenantId     String
  submissionId String
  objectKey    String
  originalName String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, objectKey])
  @@index([tenantId, submissionId])
}

model Review {
  id           String   @id @default(cuid())
  tenantId     String
  submissionId String
  reviewerId   String
  status       SubmissionStatus
  score        Int?
  feedback     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  scores       ReviewScore[]

  @@index([tenantId, submissionId, createdAt])
  @@index([tenantId, reviewerId])
}

model ReviewScore {
  id          String @id @default(cuid())
  tenantId    String
  reviewId    String
  criterionId String
  score       Int
  note        String?
  review      Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  criterion   RubricCriterion @relation(fields: [criterionId], references: [id], onDelete: Restrict)

  @@unique([reviewId, criterionId])
  @@index([tenantId, reviewId])
}

model Project {
  id        String   @id
  tenantId  String
  moduleId  String
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([tenantId, moduleId])
}

model FinalChallenge {
  id        String   @id
  tenantId  String
  courseId  String
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([tenantId, courseId])
}

model Certificate {
  id              String            @id @default(cuid())
  tenantId        String
  userId          String
  courseVersionId String
  code            String            @unique
  status          CertificateStatus @default(VALID)
  issuedAt        DateTime          @default(now())
  revokedAt       DateTime?
  revokedById     String?
  revocationReason String?
  pdfObjectKey    String?
  expiresAt       DateTime?
  payload         Json
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseVersion   CourseVersion @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  verifications   CertificateVerification[]

  @@unique([tenantId, userId, courseVersionId])
  @@index([tenantId, userId, status])
}

model CertificateVerification {
  id            String   @id @default(cuid())
  certificateId String
  code          String
  ipHash        String?
  userAgentHash String?
  result        String
  createdAt     DateTime @default(now())
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@index([code])
}

model SourceFile {
  id             String   @id @default(cuid())
  name           String
  sha256         String   @unique
  path           String
  priority       String
  condition      String
  metadata       Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SourceChunk {
  id           String   @id @default(cuid())
  sourceFileId String
  cycleId      String?
  text         String
  metadata     Json
  createdAt    DateTime @default(now())

  @@index([sourceFileId])
}

model ContentAudit {
  id        String   @id @default(cuid())
  tenantId  String
  entity    String
  entityId  String
  action    String
  note      String
  createdAt DateTime @default(now())

  @@index([tenantId, entity, entityId])
}

model ConflictLog {
  id        String   @id @default(cuid())
  sourceA   String
  sourceB   String
  decision  String
  rationale String
  createdAt DateTime @default(now())
}

model Consent {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  version     String
  purpose     String
  accepted    Boolean
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([tenantId, userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json
  createdAt DateTime @default(now())

  @@index([tenantId, actorId])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  channel   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId, channel])
}

model AIInteractionLog {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  mode           String
  promptHash     String
  redactedPrompt String
  response       String?
  consentToStore Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([tenantId, userId])
}

model LearningPlan {
  id                String   @id @default(cuid())
  tenantId          String
  userId            String
  goal              String
  weeklyHours       Int
  currentLevel      String
  targetDate        DateTime?
  focusCompetencies Json
  intensity         String
  milestones        Json
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, status])
  @@index([tenantId, createdAt])
}

model CourseQualityScore {
  id              String   @id @default(cuid())
  tenantId        String
  courseId        String
  score           Int
  status          String
  details         Json
  recommendations Json
  createdById     String
  createdAt       DateTime @default(now())
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy       User     @relation("QualityScoreCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, courseId, createdAt])
  @@index([tenantId, createdById])
}

model SupportTicket {
  id          String              @id @default(cuid())
  tenantId    String
  userId      String
  category    String
  subject     String
  description String
  severity    String
  status      SupportTicketStatus @default(OPEN)
  slaDueAt    DateTime
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, status, createdAt])
  @@index([tenantId, status, slaDueAt])
}

model PromptTemplate {
  id        String   @id
  tenantId  String
  cycleId   String?
  title     String
  template  String
  metadata  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, cycleId])
}

model AutomationTemplate {
  id        String   @id
  tenantId  String
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model AutomationSimulation {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  flow       Json
  logs       Json
  valid      Boolean
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
}

model ImportJob {
  id        String    @id @default(cuid())
  tenantId  String
  status    JobStatus @default(QUEUED)
  source    String
  result    Json?
  error     String?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, status])
}

model ExportJob {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  status    JobStatus @default(QUEUED)
  kind      String
  resultUrl String?
  error     String?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, userId, status])
}

model BillingRecord {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  provider    String
  externalId  String?
  status      String
  amountCents Int
  currency    String   @default("BRL")
  metadata    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}
