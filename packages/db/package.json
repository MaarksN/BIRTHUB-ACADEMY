{
  "name": "@inside/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "seed": "tsx seed/seed.ts"
  },
  "dependencies": {
    "@inside/content": "workspace:*",
    "@prisma/client": "6.9.0",
    "bcryptjs": "3.0.2"
  },
  "devDependencies": {
    "prisma": "6.9.0",
    "tsx": "4.20.3"
  },
  "prisma": {
    "seed": "tsx seed/seed.ts"
  }
}
